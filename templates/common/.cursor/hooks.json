{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/git-guard.cjs",
        "matcher": "\\bgit\\b"
      },
      {
        "command": "node .cursor/hooks/workflow-check.cjs",
        "matcher": "\\bgit\\b.*\\bcommit\\b"
      }
    ],
    "stop": [
      {
        "command": "node .cursor/hooks/stop-reminder.cjs"
      }
    ]
  }
}
